FROM golang:1.25-alpine AS builder
ARG TARGETARCH=amd64
WORKDIR /workspace
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} go build -o /out/korus-worker ./cmd/worker

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /out/korus-worker /korus-worker
USER nonroot:nonroot
ENTRYPOINT ["/korus-worker"]
