FROM golang:1.25-alpine AS builder
WORKDIR /workspace
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/agent-control-plane-worker ./cmd/worker

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /out/agent-control-plane-worker /agent-control-plane-worker
USER nonroot:nonroot
ENTRYPOINT ["/agent-control-plane-worker"]
